# DeepShield FinOps Environment Variables
# Copy this file to .env and fill in your actual keys.
# WARNING: NEVER commit your actual .env file to GitHub. Ensure .env is in your .gitignore!

# Alpaca Paper Trading API Keys (Get these from https://app.alpaca.markets/paper/dashboard)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# NVIDIA NIM API Key (OpenAI Compatible) - get from build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Local Server Config
PORT=4000
